<?xml version="1.0" encoding="utf-8" ?>
<odoo>
>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='pos_interface_section']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="pos_iface_load_picking" />
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="pos_iface_load_picking" string="Load Pickings" />
                        <div class="text-muted">
                            Enable the possibility to load pickings in the Point of
                            Sale
                        </div>
                        <div
                            class="content-group mt16"
                            attrs="{'invisible': [('pos_iface_load_picking', '=', False)]}"
                        >
                            <div class="row mt16">
                                <label
                                    string="Max Picking Quantity To Load"
                                    for="pos_iface_load_picking_max_qty"
                                    class="col-lg-3 o_light_label"
                                />
                                <field name="pos_iface_load_picking_max_qty" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
