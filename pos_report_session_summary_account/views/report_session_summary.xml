<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="report_session_summary"
        inherit_id="pos_report_session_summary.report_session_summary"
    >
        <xpath
            expr="//t[@t-if='o.statement_line_ids']/table/thead/tr/th[4]"
            position="after"
        >
            <th>
                <strong>Account</strong>
            </th>
        </xpath>
        <xpath
            expr="//t[@t-if='o.statement_line_ids']/table/tbody/tr/td[4]"
            position="after"
        >
            <td>
                <span
                    t-if="line.move_id.line_ids"
                    t-field="line.move_id.line_ids[0].account_id"
                />
            </td>
        </xpath>
    </template>
</odoo>
