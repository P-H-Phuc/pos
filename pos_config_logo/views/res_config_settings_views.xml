<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_config_logo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_interface_section']" position="inside">
                <setting
                    id="pos_config_logo_setting"
                    string="Alternative point of sale logo"
                    help="If set, this logo will be used instead of the company's one"
                >
                    <field name="has_pos_config_logo" />
                    <div class="content-group mt16" invisible="not has_pos_config_logo">
                        <field name="pos_config_logo" widget="image" class="w-25" />
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
