<?xml version="1.0" ?>
<odoo>
    <record id="view_res_config_settings_form_pos_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_ticket_send_by_mail
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_inventory_section']" position="after">
                <block title="Receipt Options" id="pos_receipt_options">
                    <setting
                        title="Receipt Options"
                        string="Receipt Options"
                        help="There are 4 ways of obtaining a receipt: 1.Do not send receipt via email 2.Email receipt and print it 3. Email receipt and print it unless configured on user that he only receives electronically 4.Email receipt"
                    >
                        <field name="pos_receipt_options" widget="radio" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="action_report_pos_receipt" model="ir.actions.report">
        <field name="name">Receipt</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_ticket_send_by_mail.report_receipt</field>
        <field name="report_file">pos_ticket_send_by_mail.report_receipt</field>
        <field
            name="paperformat_id"
            ref="pos_ticket_send_by_mail.paperformat_posreceipt"
        />
        <field
            name="print_report_name"
        >'POS-Receipt-'+(object.name or '').replace('/','-')</field>
    </record>
</odoo>
