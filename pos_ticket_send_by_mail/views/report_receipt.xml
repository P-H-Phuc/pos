<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_receipt_document">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
            <div class="page">
                <div class="row">
                    <div class="col-xs-12 text-center">
                        <h2 t-out="o.user_id.company_id.name" />
                        <div
                        t-field="o.partner_id"
                        t-options='{"widget": "contact", "fields": ["address", "name", "phone", "fax"], "no_marker": true, "phone_icons": true}'
                    />
                        User:
                        <span t-field="o.user_id" />
                        <br />
                        Date:
                        <span t-field="o.date_order" />
                        <br />
                    </div>
                </div>
                <div class="row" />
                <table class="table table-condensed">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-right">Quantity</th>
                            <th class="text-right">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="statements" t-value="o._get_statments()" />
                        <tr t-foreach="o.lines" t-as="line">
                            <td>
                                <span t-field="line.product_id" />
                            </td>
                            <td class="text-right">
                                <t t-if="o.state != 'cancel'">
                                    <span t-field="line.qty" />
                                </t>
                            </td>
                            <td class="text-right">
                                <t t-if="o.state != 'cancel'">
                                    <span
                                        t-out="line.price_subtotal_incl"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    />
                                </t>
                                <t t-if="line.discount != 0.0">
                                    <span t-out="line.discount" />
                                    %
                                </t>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div class="row">
                    <div class="col-xs-12 pull-right">
                        <table class="table table-condensed">
                            <tr class="border-black">
                                <td>
                                    <strong>Taxes</strong>
                                </td>
                                <td class="text-right">
                                    <span
                                        t-out="o.amount_tax"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    />
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>Total</strong>
                                </td>
                                <td class="text-right">
                                    <span
                                        t-out="o.amount_total"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    />
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
                <table class="table table-condensed">
                    <thead>
                        <tr>
                            <th>Payment Mode</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="statements" t-as="d">
                            <td>
                                <span t-out="d.journal_id.name" />
                            </td>
                            <td>
                                <span
                                    t-out="sum(d.line_ids.mapped('amount'))"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                />
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="report_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t
                    t-call="pos_ticket_send_by_mail.report_receipt_document"
                    t-lang="o.partner_id.lang"
                />
            </t>
        </t>
    </template>
</odoo>
