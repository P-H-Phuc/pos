    <t
        t-name="pos_hide_cash_control.ClosePosPopup"
        t-inherit="point_of_sale.ClosePosPopup"
        t-inherit-mode="extension"
    >
        <xpath expr="//div[contains(@class, 'total-orders')]" position="attributes">
            <attribute name="t-if">this.canSeeClosingAmounts</attribute>
        </xpath>

        <xpath
            expr="//button[contains(@class, 'icon fa fa-clone btn btn-secondary')]"
            position="attributes"
        >
            <attribute name="t-if">this.canSeeClosingAmounts</attribute>
        </xpath>

        <xpath expr="//div[@class='payment-methods-overview']" position="attributes">
            <attribute name="t-if">this.canSeeClosingAmounts</attribute>
        </xpath>

        <xpath
            expr="//button[contains(@class, 'button icon btn btn-secondary')]"
            position="attributes"
        >
            <attribute name="t-if">this.canSeeClosingAmounts</attribute>
        </xpath>
    </t>
</templates>
