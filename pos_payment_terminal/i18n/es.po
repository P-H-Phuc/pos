#. module: pos_payment_terminal
#. odoo-javascript
#: code:addons/pos_payment_terminal/static/src/js/payment_terminal.esm.js:0
msgid ""
"Please press the red button on the payment terminal to cancel the "
"transaction."
msgstr ""
"Pulse el botón rojo del terminal de pago para cancelar la transacción."

#. module: pos_payment_terminal
