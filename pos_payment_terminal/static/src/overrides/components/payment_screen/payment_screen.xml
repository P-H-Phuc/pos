<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.PaymentScreenBack" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('btn-switchpane')]" position="attributes">
            <attribute
                name="t-if"
            >currentOrder.shouldHideReturnToBasketButton()</attribute>
        </xpath>
        <xpath expr="//button[hasclass('back')]" position="attributes">
            <attribute
                name="t-attf-class"
                separator=" "
                add="{{ currentOrder.shouldHideReturnToBasketButton() ? 'disabled' : ''}}"
            />
        </xpath>
    </t>

</templates>
