<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="after">
                <block title="Meal Vouchers" id="pos_meal_voucher">
                    <setting
                        string="Maximum Amount"
                        help="Optional maximum amount per order that can be paid by meal vouchers. Set to 0 to disable."
                    >
                        <field name="pos_max_meal_voucher_amount" />
                    </setting>
                    <setting
                        string="Icon on Order Lines"
                        help="If checked, an icon will be displayed on point of sale order lines (on the product screen) for products that can be paid for by meal vouchers."
                    >
                        <field name="pos_enable_meal_voucher_order_lines_icon" />
                    </setting>
                    <setting
                        string="Information on Receipt"
                        help="If checked, an asterisk (*) will be displayed on receipts before each product that can be paid for by meal vouchers as well as the total eligible amount."
                    >
                        <field name="pos_enable_meal_voucher_receipt_info" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
