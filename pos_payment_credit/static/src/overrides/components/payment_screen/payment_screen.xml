<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath
            expr="//div[hasclass('payment-summary')]/PaymentScreenPaymentLines"
            position="after"
        >
            <section
                t-if="pos.paymentCreditInProgress"
                class="p-3 rounded-3 border border-primary border-primary text-primary"
            >
                <div
                    class="d-flex flex-column-reverse flex-lg-row justify-content-between"
                >
                    <div class="d-flex justify-content-between flex-grow-1">
                        <span t-out="pos.paymentCreditText" />
                    </div>
                </div>
            </section>
        </xpath>
    </t>
    <t t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]" position="before">
            <div t-if="currentOrder.get_partner()" class="js_customer_credit mb-2">
                <t t-set="partner" t-value="currentOrder.get_partner()" />
                <t t-if="partner.credit_amount">
                    <div
                        class="d-flex py-2 px-3 justify-content-between partner-credit w-100 lh-lg text-truncate bg-white text-primary rounded-3"
                    >
                        <span class="fs-4">Available Credit</span>
                        <span t-out="env.utils.formatCurrency(partner.credit_amount)" />
                    </div>
                </t>
            </div>
            <div class="js_customer_credit_payment" />
        </xpath>
    </t>

    <!-- <t t-inherit="point_of_sale.PartnerList" t-inherit-mode="extension">
        <xpath expr="//th[hasclass('partner-line-email')]" position="after">
            <th class="partner-line-credit pos-right-align py-2">Credit</th>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.PartnerLine" t-inherit-mode="extension">
        <xpath expr="//td[hasclass('partner-line-email')]" position="after">
            <td class="partner-line-credit available-credit p-1">
                <t t-out="env.utils.formatCurrency(props.partner.credit_amount)" />
            </td>
        </xpath>
    </t> -->

</templates>
